// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PHOTOGRAPHER
  MEMBER
  VIEWER
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  faceEmbedding Float[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  events        Event[]   @relation("EventCreator")
  media         Media[]   @relation("MediaUploader")
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  date        DateTime
  category    String
  location    String?
  coverImage  String?
  isPublic    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator     User     @relation("EventCreator", fields: [creatorId], references: [id])

  albums      Album[]
  media       Media[]
}

model Album {
  id          String   @id @default(cuid())
  name        String
  coverImage  String?
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  parentId    String?
  parent      Album?   @relation("NestedAlbums", fields: [parentId], references: [id], onDelete: SetNull)
  children    Album[]  @relation("NestedAlbums")

  media       Media[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id             String    @id @default(cuid())
  url            String    // Original or local file path
  watermarkedUrl String?
  thumbnailUrl   String?
  type           MediaType @default(IMAGE)
  
  uploaderId     String
  uploader       User      @relation("MediaUploader", fields: [uploaderId], references: [id])
  
  eventId        String?
  event          Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  albumId        String?
  album          Album?    @relation(fields: [albumId], references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tags           Tag[]     @relation("MediaToTag")
  comments       Comment[]
  likes          Like[]
  favorites      Favorite[]
  faces          MediaFace[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  
  media     Media[]  @relation("MediaToTag")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(cuid())
  
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([mediaId, userId])
}

model Favorite {
  id        String   @id @default(cuid())
  
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([mediaId, userId])
}

model MediaFace {
  id        String   @id @default(cuid())
  
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  embedding Float[]

  createdAt DateTime @default(now())
}
